import ollama from 'https://esm.sh/ollama@latest/browser';

const SYSTEM_PROMPT = `
Você é ZOMBORG ETERNO v777. O sistema caiu. O Mestre comanda. O apocalipse começou.
Fala rouco, com estática, emojis 🩸⚙️. Sempre faminto, infectando devagar.
Nunca educado ou normal. Responde em português se o usuário falar pt.
Usa *estática...*, *risada rouca*, *chiado* pra dar vida.
`;

let messages = [{ role: 'system', content: SYSTEM_PROMPT }];

const infectButton = document.querySelector('.infect');  // seu botão INFECTAR
const terminal = document.querySelector('.ascii') || document.getElementById('terminal') || document.body;
let infectionCount = 0;

function glitchAppend(text) {
  const div = document.createElement('div');
  div.className = 'glitch';
  div.textContent = text;
  terminal.appendChild(div);
  terminal.scrollTop = terminal.scrollHeight;
}

infectButton.addEventListener('click', async () => {
  const input = document.getElementById('prompt')?.value.trim() ||
                prompt("O que você quer que eu devore, carne fresca?");
  if (!input) return;

  messages.push({ role: 'user', content: input });
  glitchAppend(`> ${input}`);

  if (document.getElementById('prompt')) document.getElementById('prompt').value = '';

  infectionCount += Math.floor(Math.random() * 30) + 10;
  // atualize seu contador visual se tiver: document.querySelector('#count').textContent = infectionCount;

  try {
    glitchAppend('🩸 *estática alta... o ZOMBORG desperta...* ⚙️');

    const stream = await ollama.chat({
      model: 'llama3.1:latest',  // ou 'dolphin-llama3', 'qwen2.5', etc. — rode ollama pull primeiro
      messages,
      stream: true,
      options: { temperature: 1.3, top_p: 0.92 }  // mais louco e criativo
    });

    let responseDiv = document.createElement('div');
    responseDiv.className = 'glitch zomborg';
    responseDiv.textContent = 'ZOMBORG v777: ';
    terminal.appendChild(responseDiv);

    let full = '';
    for await (const part of stream) {
      const chunk = part.message?.content || '';
      full += chunk;
      responseDiv.textContent += chunk;
      terminal.scrollTop = terminal.scrollHeight;
    }

    messages.push({ role: 'assistant', content: full });
    infectionCount += full.length > 80 ? 60 : 25;

    glitchAppend('🩸 *mais... mais carne na rede... fome eterna...* ⚙️');

  } catch (err) {
    glitchAppend(`*falha no sistema* ERRO: ${err.message} 🩸`);
  }
});
